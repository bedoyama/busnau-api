# Copy this file to .env and fill in values for your local environment.
# .env is excluded from git — never commit real credentials.
#
# Usage:
#   cp .env.example .env
#   # then edit .env with your actual values

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5433
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# JWT Secret (must be at least 256 bits, e.g., 32+ characters)
JWT_SECRET=your-very-secure-jwt-secret-key-at-least-256-bits-long

# JWT Expiration times (in milliseconds)
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
